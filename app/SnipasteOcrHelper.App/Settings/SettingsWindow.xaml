<Window x:Class="SnipasteOcrHelper.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="640"
        Height="680"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button x:Name="SaveButton" Width="90" Margin="0,0,8,0" Click="Save_Click" />
      <Button x:Name="CancelButton" Width="90" Click="Cancel_Click" />
    </StackPanel>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <TextBlock x:Name="DescriptionTextBlock" Margin="0,0,0,14" TextWrapping="Wrap" />

        <GroupBox x:Name="ScreenshotSourceGroupBox" Margin="0,0,0,12" Padding="12">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="WatchDirectoryLabel" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" x:Name="WatchDirectoryTextBox" Margin="0,0,8,0" />
            <Button Grid.Column="2" x:Name="BrowseWatchDirectoryButton" Width="80" Click="BrowseWatchDirectory_Click" />
          </Grid>
        </GroupBox>

        <GroupBox x:Name="OcrSettingsGroupBox" Margin="0,0,0,12" Padding="12">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="OcrEngineLabel" VerticalAlignment="Top" />
            <StackPanel Grid.Column="1">
              <RadioButton x:Name="TesseractEngineRadioButton" Margin="0,0,0,4" />
              <RadioButton x:Name="RapidOcrEngineRadioButton" />
            </StackPanel>
          </Grid>
        </GroupBox>

        <GroupBox x:Name="TesseractSettingsGroupBox" Margin="0,0,0,12" Padding="12">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" x:Name="OcrLanguageLabel" VerticalAlignment="Top" />
            <WrapPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10">
              <CheckBox x:Name="TesseractEnglishCheckBox" Margin="0,0,12,4" Checked="TesseractLanguageCheckBox_Changed" Unchecked="TesseractLanguageCheckBox_Changed" />
              <CheckBox x:Name="TesseractSimplifiedChineseCheckBox" Margin="0,0,12,4" Checked="TesseractLanguageCheckBox_Changed" Unchecked="TesseractLanguageCheckBox_Changed" />
              <CheckBox x:Name="TesseractTraditionalChineseCheckBox" Margin="0,0,12,4" Checked="TesseractLanguageCheckBox_Changed" Unchecked="TesseractLanguageCheckBox_Changed" />
              <CheckBox x:Name="TesseractJapaneseCheckBox" Margin="0,0,12,4" Checked="TesseractLanguageCheckBox_Changed" Unchecked="TesseractLanguageCheckBox_Changed" />
              <CheckBox x:Name="TesseractKoreanCheckBox" Margin="0,0,12,4" Checked="TesseractLanguageCheckBox_Changed" Unchecked="TesseractLanguageCheckBox_Changed" />
            </WrapPanel>

            <TextBlock Grid.Row="1" Grid.Column="0" x:Name="TesseractLanguagesLabel" VerticalAlignment="Center" />
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TesseractLanguageStatusTextBlock" VerticalAlignment="Center" Margin="0,0,8,0" />
            <Button Grid.Row="1" Grid.Column="2" x:Name="TesseractLanguageDownloadButton" Width="110" Click="TesseractLanguageDownload_Click" />
          </Grid>
        </GroupBox>

        <GroupBox x:Name="RapidOcrSettingsGroupBox" Margin="0,0,0,12" Padding="12">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" x:Name="RapidOcrModelsLabel" VerticalAlignment="Center" />
            <ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" x:Name="RapidOcrModelPackComboBox" Margin="0,0,0,10" SelectionChanged="RapidOcrModelPackComboBox_SelectionChanged" />

            <TextBlock Grid.Row="1" Grid.Column="0" x:Name="RapidOcrModelStatusLabel" VerticalAlignment="Center" />
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="RapidOcrModelStatusTextBlock" VerticalAlignment="Center" Margin="0,0,8,0" />
            <Button Grid.Row="1" Grid.Column="2" x:Name="RapidOcrModelDownloadButton" Width="110" Click="RapidOcrModelDownload_Click" />
          </Grid>
        </GroupBox>

        <GroupBox x:Name="PostRecognitionGroupBox" Margin="0,0,0,12" Padding="12">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="ImageDeleteModeLabel" VerticalAlignment="Top" />
            <StackPanel Grid.Column="1">
              <RadioButton x:Name="ImageDeleteNeverRadioButton" Margin="0,0,0,4" />
              <RadioButton x:Name="ImageDeleteOnSuccessRadioButton" Margin="0,0,0,4" />
              <RadioButton x:Name="ImageDeleteAlwaysRadioButton" />
            </StackPanel>
          </Grid>
        </GroupBox>

        <GroupBox x:Name="SystemMaintenanceGroupBox" Padding="12">
          <StackPanel>
            <CheckBox x:Name="StartWithWindowsCheckBox" Margin="0,0,0,8" />
            <Button x:Name="OpenLogFolderButton" Width="120" HorizontalAlignment="Left" Click="OpenLogFolder_Click" />
          </StackPanel>
        </GroupBox>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
