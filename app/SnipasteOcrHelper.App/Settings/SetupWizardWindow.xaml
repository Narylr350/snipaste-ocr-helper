<Window x:Class="SnipasteOcrHelper.Settings.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="640"
        Height="620"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button x:Name="DownloadButton" Width="160" Margin="0,0,8,0" Click="DownloadButton_Click" />
      <Button x:Name="FinishButton" Width="110" Margin="0,0,8,0" Click="Finish_Click" />
      <Button x:Name="CancelButton" Width="90" Click="Cancel_Click" />
    </StackPanel>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <TextBlock x:Name="FeatureIntroTextBlock" Margin="0,0,0,14" TextWrapping="Wrap" />

        <GroupBox x:Name="ScreenshotSourceGroupBox" Margin="0,0,0,12" Padding="12">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" x:Name="WatchDirectoryLabel" VerticalAlignment="Center" />
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="WatchDirectoryTextBox" Margin="0,0,8,0" />
            <Button Grid.Row="0" Grid.Column="2" x:Name="BrowseWatchDirectoryButton" Width="80" Click="BrowseWatchDirectory_Click" />
            <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" x:Name="WatchDirectoryHelpTextBlock" Margin="0,6,0,0" TextWrapping="Wrap" Foreground="Gray" />
          </Grid>
        </GroupBox>

        <GroupBox x:Name="OcrSettingsGroupBox" Margin="0,0,0,12" Padding="12">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="OcrEngineLabel" VerticalAlignment="Top" />
            <StackPanel Grid.Column="1">
              <RadioButton x:Name="TesseractEngineRadioButton" Margin="0,0,0,4" Checked="OcrEngineRadioButton_Changed" />
              <RadioButton x:Name="RapidOcrEngineRadioButton" Checked="OcrEngineRadioButton_Changed" />
              <TextBlock x:Name="OcrEngineHelpTextBlock" Margin="0,6,0,0" TextWrapping="Wrap" Foreground="Gray" />
            </StackPanel>
          </Grid>
        </GroupBox>

        <GroupBox x:Name="TesseractSettingsGroupBox" Margin="0,0,0,12" Padding="12">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="OcrLanguageLabel" VerticalAlignment="Top" />
            <StackPanel Grid.Column="1">
              <WrapPanel>
                <CheckBox x:Name="TesseractEnglishCheckBox" Margin="0,0,12,4" Checked="TesseractLanguageCheckBox_Changed" Unchecked="TesseractLanguageCheckBox_Changed" />
                <CheckBox x:Name="TesseractSimplifiedChineseCheckBox" Margin="0,0,12,4" Checked="TesseractLanguageCheckBox_Changed" Unchecked="TesseractLanguageCheckBox_Changed" />
                <CheckBox x:Name="TesseractTraditionalChineseCheckBox" Margin="0,0,12,4" Checked="TesseractLanguageCheckBox_Changed" Unchecked="TesseractLanguageCheckBox_Changed" />
                <CheckBox x:Name="TesseractJapaneseCheckBox" Margin="0,0,12,4" Checked="TesseractLanguageCheckBox_Changed" Unchecked="TesseractLanguageCheckBox_Changed" />
                <CheckBox x:Name="TesseractKoreanCheckBox" Margin="0,0,12,4" Checked="TesseractLanguageCheckBox_Changed" Unchecked="TesseractLanguageCheckBox_Changed" />
              </WrapPanel>
              <TextBlock x:Name="TesseractLanguagesHelpTextBlock" Margin="0,6,0,0" TextWrapping="Wrap" Foreground="Gray" />
            </StackPanel>
          </Grid>
        </GroupBox>

        <GroupBox x:Name="RapidOcrSettingsGroupBox" Margin="0,0,0,12" Padding="12">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="RapidOcrModelsLabel" VerticalAlignment="Top" />
            <StackPanel Grid.Column="1">
              <ComboBox x:Name="RapidOcrModelPackComboBox" SelectionChanged="RapidOcrModelPackComboBox_SelectionChanged" />
              <TextBlock x:Name="RapidOcrModelHelpTextBlock" Margin="0,6,0,0" TextWrapping="Wrap" Foreground="Gray" />
            </StackPanel>
          </Grid>
        </GroupBox>

        <GroupBox x:Name="ResourceStatusGroupBox" Padding="12">
          <StackPanel>
            <TextBlock x:Name="DownloadHelpTextBlock" Margin="0,0,0,6" TextWrapping="Wrap" Foreground="Gray" />
            <TextBlock x:Name="StatusTextBlock" TextWrapping="Wrap" />
          </StackPanel>
        </GroupBox>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
