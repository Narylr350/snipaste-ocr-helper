<Window x:Class="SnipasteOcrHelper.History.OcrHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="760"
        Height="420"
        MinWidth="620"
        MinHeight="320"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" x:Name="EmptyMessageTextBlock" Margin="0,0,0,12" />

    <DataGrid Grid.Row="1"
              x:Name="HistoryDataGrid"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              IsReadOnly="True">
      <DataGrid.Columns>
        <DataGridTextColumn x:Name="TimeColumn" Binding="{Binding Time}" Width="150" />
        <DataGridTextColumn x:Name="FileColumn" Binding="{Binding FileName}" Width="180" />
        <DataGridTextColumn x:Name="StatusColumn" Binding="{Binding Status}" Width="110" />
        <DataGridTextColumn x:Name="DetailColumn" Binding="{Binding Detail}" Width="*" />
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</Window>
