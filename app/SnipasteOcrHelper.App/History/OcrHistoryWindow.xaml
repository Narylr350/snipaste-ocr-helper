<Window x:Class="SnipasteOcrHelper.History.OcrHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="860"
        Height="520"
        MinWidth="700"
        MinHeight="380"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="2*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" x:Name="EmptyMessageTextBlock" Margin="0,0,0,12" />

    <DataGrid Grid.Row="1"
              x:Name="HistoryDataGrid"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              ClipboardCopyMode="IncludeHeader"
              IsReadOnly="True"
              RowHeight="28"
              SelectionChanged="HistoryDataGrid_SelectionChanged"
              SelectionMode="Single"
              SelectionUnit="FullRow">
      <DataGrid.Resources>
        <Style x:Key="CompactCellText" TargetType="TextBlock">
          <Setter Property="TextTrimming" Value="CharacterEllipsis" />
          <Setter Property="TextWrapping" Value="NoWrap" />
          <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
      </DataGrid.Resources>
      <DataGrid.Columns>
        <DataGridTextColumn x:Name="TimeColumn" Binding="{Binding Time}" ElementStyle="{StaticResource CompactCellText}" Width="145" />
        <DataGridTextColumn x:Name="FileColumn" Binding="{Binding FileName}" ElementStyle="{StaticResource CompactCellText}" Width="200" />
        <DataGridTextColumn x:Name="StatusColumn" Binding="{Binding Status}" ElementStyle="{StaticResource CompactCellText}" Width="90" />
        <DataGridTextColumn x:Name="DetailColumn" Binding="{Binding Detail}" ElementStyle="{StaticResource CompactCellText}" Width="*" />
      </DataGrid.Columns>
    </DataGrid>

    <TextBlock Grid.Row="2" x:Name="DetailLabel" Margin="0,12,0,6" />
    <TextBox Grid.Row="3"
             x:Name="DetailTextBox"
             AcceptsReturn="True"
             IsReadOnly="True"
             TextWrapping="Wrap"
             VerticalScrollBarVisibility="Auto" />
  </Grid>
</Window>
